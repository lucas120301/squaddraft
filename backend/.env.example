ENVIRONMENT=development
# Supabase Postgres (Settings → Database → URI). postgresql:// works; asyncpg driver is added automatically.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
FRONTEND_ORIGIN=http://localhost:3000
CLIENT_TOKEN_SECRET=dev-secret-change-in-production
ROOM_CODE_SECRET=dev-room-secret
SIMULATION_VERSION=1.0.0
